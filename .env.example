#사용자 정보
ALLOWED_EMAILS=testing@test.test

#GOOGLE_OAUTH2
GOOGLE_OAUTH2_CLIENT_ID=MY_CLIENT_OAUTH2_ID
GOOGLE_OAUTH2_CLIENT_SECRET=SECRET
GOOGLE_OAUTH2_CALLBACK_URL=http://localhost:8000/auth/google

#PORT
PORT=8000

#CORS
CORS=http://localhost:3000

#Chzzk 연결 정보
NID_AUT=your_nid_aut
NID_SES=your_nid_ses

#DB 연결 정보
DB_TYPE=db
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=password
DB_DATABASE=chzzk_notification

#MQTT 연결 정보
MQTT_URL=mqtt://localhost
MQTT_BASE_TOPIC=chzzk-notification

# COOLSMS 정보
SMS_API_KEY=COOLSMS_API_KEY
SMS_SECRET_KEY=COOLSMS_SECRET_KEY
SMS_TO=010-0000-0000
SMS_FROM=010-0000-0001,010-0000-0002
#TRUE, FALSE, true, false 중 하나여야 함
SMS_ENABLE=TRUE